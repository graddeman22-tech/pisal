modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["zip"]

[[ports]]
localPort = 8080
externalPort = 8099

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 9000

[[ports]]
localPort = 8083
externalPort = 6000

[[ports]]
localPort = 8084
externalPort = 6800

[[ports]]
localPort = 8085
externalPort = 3000

[[ports]]
localPort = 8086
externalPort = 3003

[[ports]]
localPort = 19112
externalPort = 5000

[[ports]]
localPort = 19113
externalPort = 5173

[[ports]]
