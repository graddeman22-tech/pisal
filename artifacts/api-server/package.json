{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx ./src/index.ts",
    "build": "mkdir -p dist && cp -r src/* dist/ && cp package.json dist/",
    "build:verify": "tsx --no-verify ./build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "@workspace/api-zod": "workspace:*",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "jsonwebtoken": "^9.0.2",
    "cross-env": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.19",
    "@types/cookie-parser": "^1.4.10",
    "esbuild": "^0.27.3",
    "tsx": "catalog:"
  }
}
