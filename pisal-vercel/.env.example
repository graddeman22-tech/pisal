# Supabase PostgreSQL connection string
# Set this in Vercel dashboard under Environment Variables → DATABASE_URL
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?sslmode=require

# For local development (Replit uses this name to avoid conflicts with its own DATABASE_URL)
SUPABASE_DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?sslmode=require
